PORT=4000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/BEKEM?appName=Cluster0
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Origin only — no /login path. Comma-separate multiple origins.
CORS_ORIGIN=https://bekem-frontend-zeta.vercel.app,http://localhost:5173
CORS_ALLOW_VERCEL_PREVIEWS=true
